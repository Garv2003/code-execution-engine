PORT=6969

MAX_WORKERS=10

DOCKER_TIMEOUT_MS=5000
DOCKER_MEMORY_LIMIT=128m
DOCKER_CPU_PERIOD=100000
DOCKER_CPU_QUOTA=50000

REDIS_URL=redis://localhost:6379

# Optional: enables job history persistence and the /dashboard/jobs endpoint
DATABASE_URL=

# Optional: comma-separated keys; leave empty to disable auth
API_KEYS=

# Optional: e.g. "sysbox-runc" for stronger container isolation
DOCKER_RUNTIME=
